generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid()) @db.Uuid
  firebaseUid String   @unique @map("firebase_uid") @db.VarChar(128)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories     Category[]
  transactions   Transaction[]
  recurringBills RecurringBill[]

  @@map("users")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String   @db.VarChar(100)
  alias     String?  @db.VarChar(100)
  typeId    String   @map("type_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryType   CategoryType    @relation(fields: [typeId], references: [id])
  transactions   Transaction[]
  recurringBills RecurringBill[]

  @@index([userId])
  @@index([typeId])
  @@map("categories")
}

model Transaction {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  categoryId          String   @map("category_id") @db.Uuid
  amount              Decimal  @db.Decimal(12, 2)
  date                DateTime @db.Date
  description         String?  @db.VarChar(255)
  paymentMethod       String?  @map("payment_method") @db.VarChar(50)
  isRecurringInstance Boolean  @default(false) @map("is_recurring_instance")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

model RecurringBill {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  name        String   @db.VarChar(150)
  amount      Decimal  @db.Decimal(12, 2)
  frequency   String   @db.VarChar(50)
  startDate   DateTime @map("start_date") @db.Date
  nextDueDate DateTime @map("next_due_date") @db.Date
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@index([nextDueDate])
  @@map("recurring_bills")
}

model CategoryType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  alias     String?  @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  categories Category[]

  @@map("category_type")
}
